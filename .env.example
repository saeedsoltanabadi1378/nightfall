# Copy this file to .env and fill in real values. Do not commit .env or real secrets.
# Used by docker-compose.yml to configure the postgres/redis/api/bot/frontend services.

# --- Telegram ---
TELEGRAM_BOT_TOKEN=

# --- Agora (voice) ---
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=

# --- Postgres ---
POSTGRES_DB=nightfall
POSTGRES_USER=nightfall
POSTGRES_PASSWORD=

# --- Auth ---
# A long, random string (32+ chars) used to sign JWTs. Generate with e.g. `openssl rand -base64 48`.
JWT_SIGNING_KEY=

# Shared dashboard login. PasswordHash format: pbkdf2$210000$<base64 salt>$<base64 hash>.
# Generate one with: ./scripts/New-AdminPasswordHash.ps1 -Password "your password"
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=

# --- Public URLs ---
# Where the Api is reachable from the internet (used for CORS + baked into the frontend build).
PUBLIC_API_BASE_URL=http://localhost:5299
# Where the frontend is reachable from the internet (used for CORS).
PUBLIC_FRONTEND_ORIGIN=http://localhost:8080
# The bot's Mini App WebApp button base URL, e.g. https://t.me/YourBotName/app (optional — DM
# role-reveal falls back to a plain message if unset).
MINI_APP_BASE_URL=

# --- Environment ---
# Local | Development | Stage | Production
ASPNETCORE_ENVIRONMENT=Production
